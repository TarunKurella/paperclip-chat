{
  "name": "paperclip-chat",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @paperclip-chat/orchestrator --filter @paperclip-chat/server --filter @paperclip-chat/ui dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @paperclip-chat/db db:generate",
    "db:migrate": "pnpm --filter @paperclip-chat/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
